data/
*.h5
*.hdf5
*.tif
*.tiff
*.shp
*.dbf
*.shx
*.prj
*.gpkg

# Model checkpoints (large binary files)
models/
*.pt
*.pth
*.ckpt
*.pkl

# Outputs & logs
outputs/
logs/
runs/
*.log
*.json

# Weights & Biases
wandb/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# C extensions
*.so

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

